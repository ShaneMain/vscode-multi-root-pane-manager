{
  "name": "multi-root-pane-manager",
  "displayName": "Multi-Root Pane Manager",
  "description": "Automatically splits panes in multi-root workspaces and routes new tabs to specific panes",
  "version": "2.0.0",
  "publisher": "ShaneMain",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ShaneMain/vscode-multi-root-pane-manager.git"
  },
  "bugs": {
    "url": "https://github.com/ShaneMain/vscode-multi-root-pane-manager/issues"
  },
  "homepage": "https://github.com/ShaneMain/vscode-multi-root-pane-manager#readme",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "multi-root",
    "workspace",
    "pane",
    "split",
    "tabs",
    "editor"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "Multi-Root Pane Manager",
      "properties": {
        "multiRootPaneManager.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable/disable automatic pane management"
        },
        "multiRootPaneManager.colorTabs": {
          "type": "boolean",
          "default": true,
          "description": "Show emoji badges on files in explorer by workspace folder"
        },
        "multiRootPaneManager.colorPanes": {
          "type": "boolean",
          "default": true,
          "description": "Apply a subtle background tint to editors based on their workspace folder"
        },
        "multiRootPaneManager.colorTerminals": {
          "type": "boolean",
          "default": true,
          "description": "Automatically switch terminal to match the active pane's workspace folder"
        },
        "multiRootPaneManager.eagerTerminals": {
          "type": "boolean",
          "default": true,
          "description": "Create a terminal for every workspace folder on startup (adopts existing ones)"
        },
        "multiRootPaneManager.terminalLayout": {
          "type": "string",
          "enum": [
            "tabs",
            "split"
          ],
          "enumDescriptions": [
            "Each folder gets a separate terminal tab",
            "Terminals are split side-by-side in one panel"
          ],
          "default": "tabs",
          "description": "How to arrange terminals for workspace folders"
        },
        "multiRootPaneManager.tabLabelFormat": {
          "type": "string",
          "enum": [
            "emoji-dir-file",
            "emoji-file",
            "dir-file",
            "none"
          ],
          "enumDescriptions": [
            "🔵 FolderName / filename.ext",
            "🔵 filename.ext",
            "FolderName / filename.ext",
            "Default VS Code tab labels (no modification)"
          ],
          "default": "emoji-dir-file",
          "description": "How to format tab labels to identify which workspace folder a file belongs to"
        },
        "multiRootPaneManager.layout": {
          "type": "string",
          "enum": [
            "grid",
            "all-right",
            "primary-focus"
          ],
          "enumDescriptions": [
            "Balanced grid: top row ceil(n/2), bottom row floor(n/2)",
            "All splits go right: | 1 | 2 | 3 | 4 |",
            "Primary folder gets 70% width, others split the remaining 30%"
          ],
          "default": "primary-focus",
          "description": "How to arrange panes for workspace folders"
        },
        "multiRootPaneManager.excludePatterns": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          },
          "description": "Glob patterns for files that should not be auto-routed (e.g., \"**/.vscode/**\", \"**/README.md\")"
        },
        "multiRootPaneManager.customEmoji": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          },
          "description": "Custom emoji badges for workspace folders (e.g., [\"🔴\", \"🔵\", \"🟢\"]). Leave empty to use defaults."
        },
        "multiRootPaneManager.sortOnStartup": {
          "type": "boolean",
          "default": true,
          "description": "Automatically sort tabs when VS Code starts"
        },
        "multiRootPaneManager.lazyPanes": {
          "type": "boolean",
          "default": true,
          "description": "Only create panes as files are opened from each workspace folder, avoiding empty panes"
        },
        "multiRootPaneManager.enableStickyTabs": {
          "type": "boolean",
          "default": true,
          "description": "Remember manually moved tabs and prevent auto-routing them"
        },
        "multiRootPaneManager.showWelcome": {
          "type": "boolean",
          "default": true,
          "description": "Show welcome notification on first activation"
        }
      }
    },
    "commands": [
      {
        "command": "multiRootPaneManager.toggle",
        "title": "Multi-Root Pane Manager: Toggle"
      },
      {
        "command": "multiRootPaneManager.reset",
        "title": "Multi-Root Pane Manager: Reset Pane Assignments"
      },
      {
        "command": "multiRootPaneManager.sortTabs",
        "title": "Multi-Root Pane Manager: Sort All Tabs"
      },
      {
        "command": "multiRootPaneManager.focusPane1",
        "title": "Multi-Root Pane Manager: Focus Pane 1"
      },
      {
        "command": "multiRootPaneManager.focusPane2",
        "title": "Multi-Root Pane Manager: Focus Pane 2"
      },
      {
        "command": "multiRootPaneManager.focusPane3",
        "title": "Multi-Root Pane Manager: Focus Pane 3"
      },
      {
        "command": "multiRootPaneManager.focusPane4",
        "title": "Multi-Root Pane Manager: Focus Pane 4"
      },
      {
        "command": "multiRootPaneManager.focusPane5",
        "title": "Multi-Root Pane Manager: Focus Pane 5"
      },
      {
        "command": "multiRootPaneManager.focusPane6",
        "title": "Multi-Root Pane Manager: Focus Pane 6"
      },
      {
        "command": "multiRootPaneManager.cyclePaneLeft",
        "title": "Multi-Root Pane Manager: Cycle Pane Left"
      },
      {
        "command": "multiRootPaneManager.cyclePaneRight",
        "title": "Multi-Root Pane Manager: Cycle Pane Right"
      },
      {
        "command": "multiRootPaneManager.openInCorrectPane",
        "title": "Multi-Root Pane Manager: Open in Correct Pane"
      },
      {
        "command": "multiRootPaneManager.newFileInActiveFolder",
        "title": "Multi-Root Pane Manager: New File in Active Folder"
      },
      {
        "command": "multiRootPaneManager.showFolderQuickPick",
        "title": "Multi-Root Pane Manager: Jump to Folder Pane"
      }
    ],
    "keybindings": [
      {
        "command": "multiRootPaneManager.focusPane1",
        "key": "ctrl+alt+1"
      },
      {
        "command": "multiRootPaneManager.focusPane2",
        "key": "ctrl+alt+2"
      },
      {
        "command": "multiRootPaneManager.focusPane3",
        "key": "ctrl+alt+3"
      },
      {
        "command": "multiRootPaneManager.focusPane4",
        "key": "ctrl+alt+4"
      },
      {
        "command": "multiRootPaneManager.focusPane5",
        "key": "ctrl+alt+5"
      },
      {
        "command": "multiRootPaneManager.focusPane6",
        "key": "ctrl+alt+6"
      },
      {
        "command": "multiRootPaneManager.cyclePaneLeft",
        "key": "ctrl+alt+left"
      },
      {
        "command": "multiRootPaneManager.cyclePaneRight",
        "key": "ctrl+alt+right"
      },
      {
        "command": "multiRootPaneManager.newFileInActiveFolder",
        "key": "ctrl+alt+n"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "multiRootPaneManager.openInCorrectPane",
          "when": "!explorerResourceIsFolder",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/node": "^25.x",
    "@types/vscode": "^1.75.0",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "@vscode/vsce": "^3.7.1",
    "eslint": "^10.1.0",
    "typescript": "^5.9.3"
  }
}
